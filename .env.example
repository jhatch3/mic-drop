# Pitch Battle environment.
# Copy to .env (gitignored) and fill in values.

# ===== Snowflake (Stream B song catalog + Stream D matches/players) =====
# Account: the part before .snowflakecomputing.com in your Snowflake URL.
#   New-style: <orgname>-<accountname>
#   Legacy:    <account_locator>.<region>     (e.g. xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=MICDROP_APP_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=MICDROP_WH
SNOWFLAKE_DATABASE=MICDROP
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=MICDROP_APP
# SNOWFLAKE_MODE=mock        # mock | real

# ===== Speech-to-text (Stream D) =====
STT_PROVIDER=mock          # mock | whisper
WHISPER_MODEL=base.en      # tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_DEVICE=cpu         # cpu | cuda
WHISPER_COMPUTE_TYPE=int8  # int8 | float16 | float32

# ===== AI MC (Stream D) =====
# Gemini roast commentary (tool-using when GEMINI_MODE=real)
GEMINI_MODE=mock                  # mock | real
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash     # verify/bump current model name
GEMINI_MAX_TOOL_CALLS=6           # cap on automatic function-calling turns
COMMENTARY_TIMEOUT_S=8.0

# ElevenLabs MC voice (streaming TTS)
ELEVENLABS_MODE=mock              # mock | real
# ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # Adam (raw /api/mc-voice default)
ELEVENLABS_MODEL=eleven_flash_v2_5         # fast streaming
ELEVENLABS_V3_MODEL=eleven_v3              # expressive (audio tags) when expressive=true
TTS_TIMEOUT_S=4.0
# Voice personas (role -> voice_id). Override with your own custom voices.
# VOICE_MC=
# VOICE_HYPE=
# VOICE_VILLAIN=
DEFAULT_VOICE_ROLE=mc
# Sound effects (ElevenLabs text-to-sound, generate-then-cache)
SFX_MODEL=eleven_text_to_sound_v2
SFX_PROMPT_INFLUENCE=0.5

# ===== Solana escrow (Stream A → D) — not yet wired =====
# ESCROW_MODE=mock           # mock | devnet
# ORACLE_KEYPAIR_PATH=./oracle-keypair.json
# PROGRAM_ID=
# SOLANA_RPC_URL=https://api.devnet.solana.com

# ===== Frontend (Stream C) =====
# VITE_API_BASE=http://localhost:8000
