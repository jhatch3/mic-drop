# Pitch Battle environment.
# Copy to .env (gitignored) and fill in values.

# ===== Snowflake (Stream B song catalog + Stream D matches/players) =====
# Account: the part before .snowflakecomputing.com in your Snowflake URL.
#   New-style: <orgname>-<accountname>
#   Legacy:    <account_locator>.<region>     (e.g. xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=MICDROP_APP_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=MICDROP_WH
SNOWFLAKE_DATABASE=MICDROP
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=MICDROP_APP
# SNOWFLAKE_MODE=mock        # mock | real

# ===== Speech-to-text (Stream D) =====
STT_PROVIDER=mock          # mock | whisper
WHISPER_MODEL=base.en      # tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_DEVICE=cpu         # cpu | cuda
WHISPER_COMPUTE_TYPE=int8  # int8 | float16 | float32

# ===== AI (Stream D) — not yet wired =====
# GEMINI_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ===== Solana escrow (Stream A → D) =====
# Mode flip: mock returns a fake payout_tx; devnet signs settle() with the
# backend oracle keypair below. Match it on the laptop with the same value.
ESCROW_MODE=mock                                # mock | devnet
ORACLE_KEYPAIR_PATH=./oracle-keypair.json       # auto-generated on devnet if missing
PROGRAM_ID=2eMwChdNVoxeoWjdaiTuBGasDiHCKN3jbw7dL5eSyuZf
SOLANA_RPC_URL=https://api.devnet.solana.com
TREASURY_PUBKEY=2KnfMtidoDSVYxJDBNEK1e77rVQijvJ71zkBgz6kwejm
FEE_BPS=100                                     # 1% (must match frontend FEE_BPS)

# ===== Frontend (Stream C) =====
# VITE_API_BASE=http://localhost:8000        # leave empty in dev (Vite proxies /api)
# VITE_SERVER_URL=http://localhost:3001      # Socket.io session server
# VITE_RPC_URL=https://api.devnet.solana.com
