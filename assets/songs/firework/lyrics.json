{
  "song_id": "firework",
  "segment_start_sec": 70.0,
  "lines": [
    {
      "t": 2.78,
      "text": "Come on, let your colors burst",
      "end": 6.74
    },
    {
      "t": 6.74,
      "text": "Make 'em go, \"Ah, ah, ah\"",
      "end": 9.89
    },
    {
      "t": 9.89,
      "text": "You're gonna leave them all in awe, awe, awe",
      "end": 15.82
    },
    {
      "t": 15.82,
      "text": "You don't have to feel like a wasted space",
      "end": 19.84
    },
    {
      "t": 19.84,
      "text": "You're original, cannot be replaced",
      "end": 23.73
    },
    {
      "t": 23.73,
      "text": "If you only knew what the future holds",
      "end": 27.32
    },
    {
      "t": 27.32,
      "text": "After a hurricane comes a rainbow",
      "end": 31.16
    },
    {
      "t": 31.16,
      "text": "Maybe a reason why all the doors are closed",
      "end": 35.06
    },
    {
      "t": 35.06,
      "text": "So you could open one that leads you to the perfect road",
      "end": 39.15
    },
    {
      "t": 39.15,
      "text": "Like a lightning bolt, your heart will glow",
      "end": 42.81
    },
    {
      "t": 42.81,
      "text": "And when it's time, you'll know",
      "end": 45.07
    },
    {
      "t": 45.07,
      "text": "You just gotta ignite the light",
      "end": 49.82
    },
    {
      "t": 49.82,
      "text": "And let it shine",
      "end": 50.0
    }
  ]
}
